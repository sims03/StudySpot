<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:layout_marginTop="10dp"
    android:padding="14dp">

    <!-- Name + Rating row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#3D2B1F"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C4883A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rating"
            android:textColor="#F5F0E8"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp" />

    </LinearLayout>

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#8A7F72"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="8dp" />

    <!-- Address -->
    <TextView
        android:id="@+id/tvAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#3D2B1F"
        android:textSize="12sp"
        android:layout_marginTop="6dp" />

    <!-- Phone -->
    <TextView
        android:id="@+id/tvPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#3D2B1F"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

    <!-- Website -->
    <TextView
        android:id="@+id/tvWebsite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#C4883A"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

    <!-- Features -->
    <TextView
        android:id="@+id/tvFeatures"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#3D2B1F"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

    <!-- Noise + Reviews row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvNoise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:textColor="#3D2B1F"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvReviews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8A7F72"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Рејтинг ѕвезди -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_badge"
        android:padding="10dp"
        android:layout_marginTop="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Оцени го ова место:"
            android:textColor="#8A7F72"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/ratingStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/star1" android:layout_width="36dp"
                android:layout_height="36dp" android:text="☆"
                android:textSize="26sp" android:gravity="center"
                android:textColor="#C4883A" android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/star2" android:layout_width="36dp"
                android:layout_height="36dp" android:text="☆"
                android:textSize="26sp" android:gravity="center"
                android:textColor="#C4883A" android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/star3" android:layout_width="36dp"
                android:layout_height="36dp" android:text="☆"
                android:textSize="26sp" android:gravity="center"
                android:textColor="#C4883A" android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/star4" android:layout_width="36dp"
                android:layout_height="36dp" android:text="☆"
                android:textSize="26sp" android:gravity="center"
                android:textColor="#C4883A" android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/star5" android:layout_width="36dp"
                android:layout_height="36dp" android:text="☆"
                android:textSize="26sp" android:gravity="center"
                android:textColor="#C4883A" android:clickable="true" android:focusable="true" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>